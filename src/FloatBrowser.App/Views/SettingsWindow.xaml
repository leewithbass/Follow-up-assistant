<Window x:Class="FloatBrowser.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="420" Width="500" WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer>
            <StackPanel>
                <TextBlock Text="后退快捷键"/><TextBox Text="{Binding Back, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="前进快捷键"/><TextBox Text="{Binding Forward, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="刷新快捷键"/><TextBox Text="{Binding Refresh, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="显示/隐藏窗口快捷键"/><TextBox Text="{Binding ToggleVisibility, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="主页快捷键"/><TextBox Text="{Binding Home, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="播放/暂停快捷键"/><TextBox Text="{Binding PlayPauseMedia, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="主页URL"/><TextBox Text="{Binding HomeUrl, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="{Binding Message}" Foreground="OrangeRed" Margin="0,6,0,0"/>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Right">
            <Button Content="恢复默认" Margin="0,0,8,0" Command="{Binding RestoreDefaultsCommand}"/>
            <Button Content="保存" Margin="0,0,8,0" Command="{Binding SaveCommand}"/>
            <Button Content="关闭" Click="OnClose"/>
        </StackPanel>
    </Grid>
</Window>
